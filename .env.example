# App
NODE_ENV=development
APP_URL=http://localhost:3000
ROBOTS_BASE_URL=http://localhost:3000
GOOGLE_SITE_VERIFICATION=
NOMINATIM_CONTACT_EMAIL=
# NOMINATIM_USER_AGENT=BiziDashboard/1.0 (https://example.com; ops@example.com)
# NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
# NOMINATIM_MIN_INTERVAL_MS=1000

# City configuration
CITY=zaragoza

# Database (PostgreSQL) - use schema param for multi-city
DATABASE_URL=postgresql://bizi:bizi_password@localhost:5432/bizidashboard?schema=zaragoza

# Redis
REDIS_URL=redis://localhost:6379

# Mobile API Authentication (REQUIRED in production)
JWT_SECRET=change-me-in-production
SIGNATURE_SECRET=change-me-in-production

# Mobile API App Versions (optional - JSON format)
# APP_VERSIONS='{"minVersion":"1.0.0","maxVersion":"999.999.999","versions":[]}'

# Internal jobs
ENABLE_INTERNAL_JOBS=false

# Manual collect trigger security
COLLECT_API_KEY=change-me
COLLECT_RATE_LIMIT_MAX=6
COLLECT_RATE_LIMIT_WINDOW_MS=60000

# GBFS source (configurable per city)
GBFS_URL=https://zaragoza.publicbikesystem.net/customer/gbfs/v2/gbfs.json
GBFS_REQUEST_TIMEOUT_MS=20000
GBFS_MAX_RETRIES=5
GBFS_RETRY_BASE_DELAY_MS=1000

# Sentry (Observability)
# Client events need NEXT_PUBLIC_SENTRY_DSN at build time. Optional server-only fallback:
# SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_DSN=

# Umami (Analytics)
# NEXT_PUBLIC_UMAMI_SCRIPT_SRC=https://cloud.umami.is/script.js
# NEXT_PUBLIC_UMAMI_WEBSITE_ID=
