# Your Sentry DSN (from your Sentry account)
VITE_SENTRY_DSN=
SENTRY_DSN=
VITE_SENTRY_TRACE_SAMPLE_RATE=0.2
SENTRY_DYNACONF_RELEASE=0.0.1

# Browser analytics (read by the server at runtime)
UMAMI_SCRIPT_SRC=https://cloud.umami.is/script.js
UMAMI_WEBSITE_ID=
UMAMI_HOST_URL=https://api-gateway.umami.dev

# Runtime security
APP_URL=http://localhost:3000
MOBILE_API_ENABLED=false
MOBILE_API_ALLOWED_ORIGINS=
REQUIRE_SIGNED_MOBILE_REQUESTS=false
CSP_REPORT_ONLY=true
CSP_SCRIPT_SRC_ORIGINS=
CSP_CONNECT_SRC_ORIGINS=

# Your Sentry organization (from your Sentry account)
# VITE_SENTRY_ORG=
# VITE_SENTRY_PROJECT=
# SENTRY_AUTH_TOKEN=

# Database URL for PostgreSQL
DATABASE_URL="postgresql://username:password@localhost:5432/mydb"
