{
  "name": "bizidashboard",
  "version": "0.1.0",
  "license": "GPL-3.0-only",
  "private": true,
  "type": "module",
  "packageManager": "bun@latest",
  "imports": {
    "#/*": "./src/*",
    "@/*": "./src/*"
  },
  "engines": {
    "node": ">=20.0.0",
    "bun": ">=1.3.10"
  },
  "scripts": {
    "dev": "dotenv -e .env.local -- sh -c \"NODE_OPTIONS='--import ./instrument.server.mjs' vite dev --port 3000\"",
    "build": "vite build && cp instrument.server.mjs .output/server",
    "preview": "vite preview",
    "start": "node --import ./.output/server/instrument.server.mjs .output/server/index.mjs",
    "lint": "eslint",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:install": "playwright install chromium",
    "db:health": "tsx scripts/db-health-check.ts",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "prisma db seed",
    "qa:seed": "tsx scripts/seed-qa-db.ts",
    "qa:audit": "tsx scripts/site-audit.ts",
    "qa:audit:check": "tsx scripts/check-site-audit.ts",
    "qa:validate:site-env": "node scripts/validate-site-env.mjs",
    "qa:vitals:prod": "node scripts/collect-dashboard-vitals.mjs",
    "qa:vitals:check": "node scripts/check-dashboard-vitals.mjs",
    "qa:ci:local": "./scripts/run-local-ci.sh",
    "qa:audit:prod": "tsx scripts/site-audit.ts --base-url https://datosbizi.com --output ops/site-audit-report-prod.json",
    "security:audit": "bun audit"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@neondatabase/serverless": "^1.0.2",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "@sentry/tanstackstart-react": "^10.47.0",
    "@tanstack/react-devtools": "latest",
    "@tanstack/react-query": "latest",
    "@tanstack/react-query-devtools": "latest",
    "@tanstack/react-router": "latest",
    "@tanstack/react-router-devtools": "latest",
    "@tanstack/react-router-ssr-query": "^1.166.12",
    "@tanstack/react-start": "latest",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/router-plugin": "^1.132.0",
    "@tanstack/start-plugin": "latest",
    "better-auth": "^1.5.3",
    "jose": "^6.2.2",
    "lucide-react": "^0.545.0",
    "maplibre-gl": "^5.21.1",
    "node-cron": "^4.2.1",
    "pg": "^8.20.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-map-gl": "^8.1.0",
    "recharts": "^3.8.1",
    "redis": "^5.11.0",
    "server-only": "^0.0.1",
    "turndown": "^7.2.4",
    "vite-plugin-neon-new": "^0.8.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/devtools-vite": "latest",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/turndown": "^5.0.6",
    "@vitejs/plugin-react": "^6.0.1",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "jsdom": "^28.1.0",
    "prisma": "^7.6.0",
    "proj4": "^2.20.4",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.0",
    "vitest": "^4.1.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ]
  },
  "overrides": {
    "lodash": "4.17.23",
    "hono": "4.12.7",
    "@hono/node-server": "1.19.10"
  }
}
