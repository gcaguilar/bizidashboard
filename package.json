{
  "name": "bizidashboard",
  "version": "0.1.0",
  "license": "GPL-3.0-only",
  "private": true,
  "packageManager": "bun@latest",
  "engines": {
    "node": ">=20.0.0",
    "bun": ">=1.3.10"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "start:bun": "bun .next/standalone/server.js",
    "lint": "eslint",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:install": "playwright install chromium",
    "db:health": "tsx scripts/db-health-check.ts",
    "qa:seed": "tsx scripts/seed-qa-db.ts",
    "qa:audit": "tsx scripts/site-audit.ts",
    "qa:audit:check": "tsx scripts/check-site-audit.ts",
    "qa:ci:local": "./scripts/run-local-ci.sh",
    "qa:audit:prod": "tsx scripts/site-audit.ts --base-url https://datosbizi.com --output ops/site-audit-report-prod.json"
  },
  "dependencies": {
    "@libsql/client": "^0.17.0",
    "@libsql/isomorphic-ws": "^0.1.5",
    "@prisma/adapter-libsql": "^7.5.0",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@sentry/nextjs": "^10.44.0",
    "jose": "^6.2.1",
    "maplibre-gl": "^5.20.0",
    "next": "16.2.1",
    "node-cron": "^4.2.1",
    "pg": "^8.20.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-map-gl": "^8.1.0",
    "recharts": "^3.8.0",
    "redis": "^5.11.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^25.4.0",
    "@types/pg": "^8.18.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.1",
    "prisma": "^7.5.0",
    "proj4": "^2.20.4",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "typescript": "5.9.3",
    "vitest": "^4.0.18"
  },
  "overrides": {
    "lodash": "4.17.23",
    "hono": "4.12.7",
    "@hono/node-server": "1.19.10"
  }
