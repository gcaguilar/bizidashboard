{
  "name": "bizidashboard",
  "version": "0.1.0",
  "license": "GPL-3.0-only",
  "private": true,
  "packageManager": "bun@latest",
  "engines": {
    "node": ">=20.0.0",
    "bun": ">=1.3.10"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "start:bun": "bun .next/standalone/server.js",
    "lint": "mkdir -p test-results && eslint",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:install": "playwright install chromium",
    "db:health": "tsx scripts/db-health-check.ts",
    "qa:seed": "tsx scripts/seed-qa-db.ts",
    "qa:audit": "tsx scripts/site-audit.ts",
    "qa:audit:check": "tsx scripts/check-site-audit.ts",
    "qa:validate:site-env": "node scripts/validate-site-env.mjs",
    "qa:vitals:prod": "node scripts/collect-dashboard-vitals.mjs",
    "qa:vitals:check": "node scripts/check-dashboard-vitals.mjs",
    "qa:ci:local": "./scripts/run-local-ci.sh",
    "qa:audit:prod": "tsx scripts/site-audit.ts --base-url https://datosbizi.com --output ops/site-audit-report-prod.json",
    "security:audit": "bun audit"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@libsql/client": "^0.17.2",
    "@libsql/isomorphic-ws": "^0.1.5",
    "@prisma/adapter-libsql": "^7.6.0",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "@sentry/nextjs": "^10.47.0",
    "@tanstack/react-table": "^8.21.3",
    "jose": "^6.2.2",
    "maplibre-gl": "^5.21.1",
    "next": "16.2.4",
    "node-cron": "^4.2.1",
    "pg": "^8.20.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-map-gl": "^8.1.0",
    "recharts": "^3.8.1",
    "redis": "^5.11.0",
    "turndown": "^7.2.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/turndown": "^5.0.6",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.4",
    "prisma": "^7.6.0",
    "proj4": "^2.20.4",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "6.0.3",
    "vitest": "^4.1.2"
  },
  "overrides": {
    "lodash": "4.17.23",
    "hono": "4.12.7",
    "@hono/node-server": "1.19.10"
  }
}
