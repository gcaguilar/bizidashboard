{
  "name": "bizidashboard",
  "version": "0.1.0",
  "license": "GPL-3.0-only",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.14",
  "imports": {
    "#/*": "./src/*",
    "@/*": "./src/*"
  },
  "engines": {
    "node": ">=20.0.0",
    "bun": ">=1.3.10"
  },
  "scripts": {
    "dev": "dotenv -e .env.local -- vite dev --port 3000",
    "build": "rm -rf dist .output && vite build",
    "preview": "vite preview",
    "start": "bun ops/start-server.mjs",
    "lint": "eslint",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:install": "playwright install chromium",
    "db:health": "tsx scripts/db-health-check.ts",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "prisma db seed",
    "qa:seed": "tsx scripts/seed-qa-db.ts",
    "qa:audit": "bun scripts/site-audit.ts",
    "qa:audit:check": "bun scripts/check-site-audit.ts",
    "qa:validate:site-env": "node scripts/validate-site-env.mjs",
    "qa:vitals:prod": "node scripts/collect-dashboard-vitals.mjs",
    "qa:vitals:check": "node scripts/check-dashboard-vitals.mjs",
    "qa:ci:local": "./scripts/run-local-ci.sh",
    "qa:audit:prod": "bun scripts/site-audit.ts --base-url https://datosbizi.com --output ops/site-audit-report-prod.json",
    "security:audit": "bun audit"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@floating-ui/react-dom": "^2.1.8",
    "@neondatabase/serverless": "^1.1.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@sentry/tanstackstart-react": "^10.56.0",
    "@tanstack/react-devtools": "latest",
    "@tanstack/react-query": "latest",
    "@tanstack/react-query-devtools": "latest",
    "@tanstack/react-router": "latest",
    "@tanstack/react-router-devtools": "latest",
    "@tanstack/react-router-ssr-query": "^1.167.1",
    "@tanstack/react-start": "latest",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/router-plugin": "^1.168.18",
    "@tanstack/start-plugin": "latest",
    "jose": "^6.2.3",
    "maplibre-gl": "^5.24.0",
    "node-cron": "^4.2.1",
    "pg": "^8.21.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-map-gl": "^8.1.1",
    "recharts": "^3.8.1",
    "redis": "^5.12.1",
    "server-only": "^0.0.1",
    "vite-plugin-neon-new": "^0.8.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/devtools-vite": "latest",
    "@tanstack/eslint-config": "^0.4.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.9.2",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "jsdom": "^29.1.1",
    "prisma": "^7.8.0",
    "proj4": "^2.20.9",
    "rollup-plugin-visualizer": "^7.0.1",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.4",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ]
  },
  "overrides": {
    "lodash": "4.17.23",
    "hono": "4.12.7",
    "@hono/node-server": "1.19.10"
  }
}
